# Compose project name (keeps containers scoped)
COMPOSE_PROJECT_NAME=papermark_ce_local

# Postgres settings used by docker-compose.local.yml
POSTGRES_IMAGE=postgres:18-alpine
POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_USER=papermark
POSTGRES_PASSWORD=papermark
POSTGRES_DB=papermark
POSTGRES_SHADOW_DB=papermark_shadow

# App URL/auth defaults for generated root .env.local
APP_IMAGE=node:24-alpine
WEB_PORT=3003
APP_READY_TIMEOUT_SECONDS=180
APP_READY_CHECK_INTERVAL_SECONDS=2
NEXTAUTH_URL=http://localhost:3003
NEXTAUTH_SECRET=local-dev-secret-change-me
APP_BASE_HOST=localhost
WEBHOOK_BASE_HOST=localhost
